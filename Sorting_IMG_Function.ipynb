    "## Hierarchical Image Grouping by ROI and Sample Identifier"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "1382aae2",
   "metadata": {
    "scrolled": true
   },
   "outputs": [
